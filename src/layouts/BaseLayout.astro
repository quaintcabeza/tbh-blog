---
import Nav from '../components/layout/Nav.astro';
import '../assets/styles/global.scss';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const siteTitle = 'A Bee in a Bluebonnet';
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tangerine:wght@400;700&display=swap" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrapper">
        <Nav />
      </div>
    </header>
    <div class="site-banner">
      <a class="site-title" href={import.meta.env.BASE_URL}>{siteTitle}</a>
    </div>
    <main class="page-content">
      <div class="wrapper">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrapper">
        <p>&copy; {new Date().getFullYear()} {siteTitle}</p>
      </div>
    </footer>
  </body>
</html>
